DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECRET_KEY=change-me
TIME_ZONE=Europe/Warsaw

# Jeden z tych kluczy wystarczy. Bez klucza aplikacja używa trybu demo/mock.
# NIGDY nie commituj prawdziwego klucza — to plik przykładowy.
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=

# OpenAI — używane WYŁĄCZNIE do opisów czynności (analiza wideo zostaje na Gemini).
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_USE_MOCK=false

GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_VIDEO_MODEL=gemini-3.5-flash
GEMINI_USE_MOCK=false
GEMINI_FALLBACK_TO_MOCK=true

# Szacowanie kosztu analizy (USD za 1 mln tokenów) — sprawdź aktualny cennik modelu.
GEMINI_PRICE_INPUT_PER_M=0.30
GEMINI_PRICE_OUTPUT_PER_M=2.50
# Przybliżona liczba tokenów na sekundę wideo (szacunek w trybie mock).
GEMINI_VIDEO_TOKENS_PER_SECOND=263
# Klatki/sek. wysyłane do Gemini. Domyślne ~1 fps modelu nie wystarcza do
# rozróżniania szybkich ruchów (jazda prosto vs skręt) — model konfabuluje.
# Wyższy fps = więcej realnych klatek i proporcjonalnie wyższy koszt. 0 = domyślne API.
GEMINI_VIDEO_FPS=5
# Temperatura analizy (0.0 = powtarzalnie; wyżej = bardziej losowe wyniki między uruchomieniami).
GEMINI_VIDEO_TEMPERATURE=0.0
# Ziarno losowości dla powtarzalności; ujemne = nie ustawiaj.
GEMINI_VIDEO_SEED=42
# Kurs USD->PLN tylko do orientacyjnego przeliczenia w UI.
GEMINI_USD_PLN_RATE=4.00

# Opcjonalnie PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/video_process_demo
